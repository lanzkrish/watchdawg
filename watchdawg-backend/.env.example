=====================================

🐶 WatchDawg Backend Environment

=====================================

==============================

🌐 SERVER CONFIG

==============================

PORT=5000
NODE_ENV=development   # development / production

==============================

🗄 DATABASE CONFIG

==============================

Local (outside Docker):

DATABASE_URL=postgresql://watchdawg:watchdawg123@localhost:10000/watchdawg_db

Docker (inside container network):

DATABASE_URL=postgresql://watchdawg:watchdawg123@db:5432/watchdawg_db

==============================

🔐 AUTH (JWT)

==============================

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

==============================

🔐 PASSWORD HASHING

==============================

BCRYPT_SALT_ROUNDS=10

==============================

📧 EMAIL CONFIG (SMTP - Zoho)

==============================

EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=587
EMAIL_SECURE=false   # true for 465, false for 587

EMAIL_USER=your_email@zohomail.in
EMAIL_PASS=your_email_password_or_app_password
EMAIL_FROM=your_email@zohomail.in

==============================

🌍 CLIENT (FRONTEND)

==============================

CLIENT_URL=http://localhost:5173

==============================

🔌 SOCKET CONFIG

==============================

SOCKET_PORT=5000

==============================

📊 LOGGING

==============================

LOG_LEVEL=debug   # debug / info / warn / error
