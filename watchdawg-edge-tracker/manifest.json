{
  "manifest_version": 3,
  "name": "WatchDawg Tracker",
  "version": "1.0.0",
  "description": "Track active browser activity tracker",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "WatchDawg Running"
  }
}
