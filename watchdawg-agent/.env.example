=====================================

🐶 WatchDawg Agent Configuration

=====================================

==============================

🌐 API CONFIG

==============================

Backend API URL (Docker → use http://backend:5000)

API_URL=http://localhost:5000

==============================

🔌 EXTENSION BRIDGE

==============================

Local bridge server for browser extension → agent communication

EXTENSION_PORT=6969
EXTENSION_TTL=10000   # cache lifetime (ms)

==============================

⏱ TRACKING ENGINE

==============================

Core tracking loop intervals

TRACK_INTERVAL=1000      # activity capture loop (ms)
SAVE_INTERVAL=5000       # send data to backend (ms)
SOCKET_INTERVAL=2000     # realtime socket emit (ms)

==============================

🧠 IDLE TRACKING

==============================

Detect user inactivity

IDLE_THRESHOLD=60        # seconds before idle
AWAY_THRESHOLD=300       # seconds before away

==============================

🪵 LOGGER

==============================

Logging environment

NODE_ENV=development     # development / production

==============================

📸 SCREENSHOT (FUTURE FEATURE)

==============================

Screenshot capture intervals

SCREENSHOT_MIN_INTERVAL=120000   # 2 minutes
SCREENSHOT_MAX_INTERVAL=300000   # 5 minutes
