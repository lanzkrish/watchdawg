{
  "name": "watchdawg-agent",
  "version": "1.0.0",
  "description": "WorkSync Employee Monitoring Agent",
  "author": "Harsit",
  "main": "dist/main.js",

  "scripts": {
    "dev": "tsc -w",
    "build": "tsc",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },

  "dependencies": {
    "active-win": "^8.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3"
  },

  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.39",
    "@types/screenshot-desktop": "^1.15.0",
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3"
  },

  "build": {
    "appId": "com.watchdawg.agent",
    "productName": "WatchDawg Agent",

    "directories": {
      "output": "release"
    },

    "asar": true,

    "files": [
      "dist/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "public/auth/pages",
        "to": "pages"
      }
    ],

    "win": {
      "target": "nsis",
      "artifactName": "${productName} Setup ${version}.exe"
    }
  }
}
