{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* 🔥 IMPORTANT */
    "resolveJsonModule": true,
    "moduleResolution": "node",

    /* 🔥 GLOBAL TYPES */
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
